# ============================================================================
#  Modelo de variáveis — usado SÓ para rodar o backend localmente
#  (com "npm run dev" dentro da pasta "server").
# ----------------------------------------------------------------------------
#  COMO USAR:
#    1. Copie este arquivo para "server/.env"
#         (Windows:  copy .env.example .env)
#         (Linux:    cp .env.example .env)
#    2. Preencha os valores reais.
#
#  Em produção (no servidor), estas variáveis vêm do docker-compose — este
#  arquivo NÃO é usado lá.
# ============================================================================

# Banco de dados local. Suba-o antes com: docker compose up -d db
# Use o mesmo usuário/senha/nome definidos no arquivo .env da raiz do projeto.
DATABASE_URL=postgres://mural:troque-esta-senha@localhost:5432/mural

# Porta em que o backend vai escutar (o site espera a 3001).
PORT=3001

# --- Cloudflare R2 (armazenamento das fotos) --------------------------------
R2_ACCOUNT_ID=seu-account-id-da-cloudflare
R2_ACCESS_KEY_ID=sua-access-key-do-r2
R2_SECRET_ACCESS_KEY=sua-secret-key-do-r2
R2_BUCKET=mural-leo-fotos
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev
