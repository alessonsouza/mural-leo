# ============================================================================
#  Modelo de variáveis de ambiente — usado pelo docker-compose
# ----------------------------------------------------------------------------
#  COMO USAR:
#    1. Copie este arquivo para um novo arquivo chamado ".env"
#         (Windows:  copy .env.example .env)
#         (Linux:    cp .env.example .env)
#    2. Preencha os valores reais abaixo.
#    3. NUNCA compartilhe o arquivo ".env" — ele contém senhas.
# ============================================================================

# --- Endereço público do site ----------------------------------------------
# Com um domínio próprio (recomendado): o Caddy ativa o HTTPS automaticamente.
#   Exemplo:  DOMINIO=mural.seuclube.org.br
# Sem domínio (acesso pelo IP, só HTTP, para testes):
#   DOMINIO=:80
DOMINIO=mural.seuclube.org.br

# --- Banco de dados PostgreSQL ----------------------------------------------
POSTGRES_USER=mural
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=mural

# --- Cloudflare R2 (armazenamento das fotos) --------------------------------
# Estes valores são obtidos no painel da Cloudflare (ver o README).
R2_ACCOUNT_ID=seu-account-id-da-cloudflare
R2_ACCESS_KEY_ID=sua-access-key-do-r2
R2_SECRET_ACCESS_KEY=sua-secret-key-do-r2
R2_BUCKET=mural-leo-fotos
# Endereço público do bucket (o link r2.dev ou o seu domínio do bucket).
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev
